# ============================================================
# FinTrack Pro -- Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Application ---
APP_NAME=FinTrack Pro
APP_ENV=production          # development | production
APP_PORT=8080

# --- JWT Security ---
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_a_secure_256_bit_secret_key_here
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fintrack
POSTGRES_USER=fintrack
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- Frontend ---
VITE_API_BASE_URL=/api/v1
VITE_WS_URL=ws://localhost/ws
VITE_APP_NAME=FinTrack Pro

# --- Price APIs (all optional, free tiers work) ---
COINGECKO_API_KEY=
EXCHANGE_RATE_API_KEY=

# --- Price Sync Schedule ---
PRICE_SYNC_INTERVAL_MINUTES=5

# --- Notifications ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Nginx / TLS ---
DOMAIN=localhost
SSL_EMAIL=

# --- Logging ---
LOG_LEVEL=INFO

# --- Claude AI Integration (optional) ---
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_ENABLED=false
