# ============================================================
# FinTrack Pro -- Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Application ---
APP_NAME=FinTrack Pro
APP_ENV=production          # development | production
APP_PORT=8080

# --- JWT Security ---
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_a_secure_256_bit_secret_key_here
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fintrack
POSTGRES_USER=fintrack
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- Frontend ---
VITE_API_BASE_URL=/api/v1
# Leave blank to auto-derive from window.location (ws:// locally, wss:// in prod).
VITE_WS_URL=
VITE_APP_NAME=FinTrack Pro

# --- Price APIs (all optional, free tiers work) ---
COINGECKO_API_KEY=
EXCHANGE_RATE_API_KEY=

# --- Price Sync Schedule ---
PRICE_SYNC_INTERVAL_MINUTES=5

# --- Auth Rate Limits ---
# Maximum failed logins per window, and window size in seconds.
# Counter is keyed by both username and client IP. Set MAX=0 to disable.
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# --- Notifications ---
# Leave SMTP_HOST blank to disable mail. When set, the backend sends
# password reset, verification, bill reminders, and alert emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=FinTrack Pro
APP_BASE_URL=https://fatihaciroglu.dev

# --- Nginx / TLS ---
# Self-hosted production: point DOMAIN A/AAAA records at this host.
# Only relevant when the bundled Nginx is active (docker compose
# --profile nginx up -d). With external Traefik these are unused.
DOMAIN=fatihaciroglu.dev
SSL_EMAIL=aciroglu.fatih@gmail.com

# --- Traefik ingress (homelab default) ---
# When TRAEFIK_ENABLED=true, the frontend + backend containers
# publish labels that a homelab-managed Traefik will pick up.
# Layer docker-compose.traefik.yml on top of the main file to
# attach the services to TRAEFIK_NETWORK.
TRAEFIK_ENABLED=true
TRAEFIK_HOST=fatihaciroglu.dev
TRAEFIK_NETWORK=traefik-proxy
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

# --- Authelia ForwardAuth (optional) ---
# When AUTHELIA_ENABLED=true the backend trusts the Remote-User
# header injected by a Traefik + Authelia ForwardAuth middleware.
# The principal must already exist locally (username or email).
# Populate AUTHELIA_TRUSTED_IPS with the Traefik proxy IP(s) to
# prevent header-spoofing from untrusted sources.
AUTHELIA_ENABLED=false
AUTHELIA_HEADER=Remote-User
AUTHELIA_TRUSTED_IPS=

# --- Monthly Budget Report ---
# When enabled, on day 1 of each month at 09:00 Europe/Istanbul the backend
# emails every verified user a PDF summary of the previous month. Requires
# SMTP to be configured. Leave false unless you want these reports.
MONTHLY_REPORT_ENABLED=false

# --- Receipt storage ---
# Path inside the backend container where uploaded transaction receipts are
# written. Backed by the app-receipts docker volume by default. Override only
# if you want to mount the receipt files at a different path on the host.
RECEIPT_DIR=/var/lib/fintrack/receipts

# --- Backups (restic-based encrypted loop) ---
# The backup container pipes pg_dump into restic. RESTIC_REPOSITORY
# defaults to a local encrypted repo at ./backups/restic on the host;
# point it at s3:s3.amazonaws.com/bucket or b2:bucket/path to ship
# off-host. RESTIC_PASSWORD is mandatory -- the container refuses to
# start without one. Generate with: openssl rand -base64 48
RESTIC_REPOSITORY=/backups/restic
RESTIC_PASSWORD=CHANGE_ME_restic_repository_password
BACKUP_INTERVAL_SECONDS=86400
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=6
# Fill only when RESTIC_REPOSITORY targets S3 / S3-compatible storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
# Fill only when RESTIC_REPOSITORY targets Backblaze B2 (b2:bucket/path)
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=

# --- Monitoring (Prometheus + Grafana) ---
# Grafana is published on GRAFANA_PORT on the host (default 3001).
# Prometheus stays internal — it scrapes the backend's actuator endpoint.
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# --- Log shipping (optional -- Promtail -> Loki) ---
# Set to your homelab Loki push endpoint, then start with
# `docker compose --profile loki up -d` to activate the promtail sidecar.
# Leave blank to skip log shipping entirely.
LOKI_URL=

# --- Logging ---
LOG_LEVEL=INFO
# Rolling file policy for the production profile. Files rotate daily and once
# they pass LOG_MAX_FILE_SIZE; the oldest archives are pruned so the combined
# size never exceeds LOG_TOTAL_SIZE_CAP. Tune LOG_TOTAL_SIZE_CAP to whatever
# your disk can spare (accepts KB/MB/GB suffixes).
LOG_MAX_FILE_SIZE=50MB
LOG_MAX_HISTORY_DAYS=90
LOG_TOTAL_SIZE_CAP=1GB
LOG_ERROR_TOTAL_SIZE_CAP=256MB

# --- Claude AI Integration (optional) ---
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_ENABLED=false
