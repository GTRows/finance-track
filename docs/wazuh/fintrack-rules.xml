<!--
  Wazuh rules for FinTrack auth events.
  Rule IDs live in the 100000-100099 range per Wazuh convention for
  custom application rules. Adjust the base id if it collides with other
  packs on your manager.
-->

<group name="fintrack,">

  <rule id="100000" level="0">
    <decoded_as>fintrack-audit</decoded_as>
    <description>FinTrack audit event</description>
  </rule>

  <rule id="100001" level="4">
    <if_sid>100000</if_sid>
    <field name="status">^SUCCESS$</field>
    <description>FinTrack: successful $(action) by $(srcuser) from $(srcip)</description>
  </rule>

  <rule id="100002" level="6">
    <if_sid>100000</if_sid>
    <field name="status">^FAILURE$</field>
    <description>FinTrack: failed $(action) by $(srcuser) from $(srcip)</description>
    <group>authentication_failed,</group>
  </rule>

  <rule id="100003" level="10" frequency="5" timeframe="300">
    <if_matched_sid>100002</if_matched_sid>
    <same_source_ip />
    <field name="action">^LOGIN|TOTP_VERIFY$</field>
    <description>FinTrack: possible brute-force from $(srcip) -- 5 auth failures in 5 minutes</description>
    <group>authentication_failures,attack,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <rule id="100004" level="8">
    <if_sid>100000</if_sid>
    <field name="action">^PASSWORD_CHANGE|TOTP_DISABLE|PASSWORD_RESET_CONFIRMED$</field>
    <field name="status">^SUCCESS$</field>
    <description>FinTrack: sensitive account change ($(action)) by $(srcuser) from $(srcip)</description>
    <group>account_changed,</group>
  </rule>

</group>
